{
	"name": "@carlesandres/openmdr",
	"version": "0.2.0",
	"description": "TUI-first markdown reader on opentui",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/carlesandres/openmdr.git"
	},
	"bugs": {
		"url": "https://github.com/carlesandres/openmdr/issues"
	},
	"homepage": "https://github.com/carlesandres/openmdr#readme",
	"keywords": [
		"markdown",
		"reader",
		"terminal",
		"tui",
		"bun",
		"opentui",
		"glow"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"openmdr": "src/index.tsx"
	},
	"scripts": {
		"dev": "bun --watch src/index.tsx",
		"start": "bun run src/index.tsx",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --tsconfig tsconfig.json src/",
		"format": "oxfmt src/",
		"format:check": "oxfmt --check src/",
		"test": "bun test",
		"build:themes": "bun run dev/build-themes.ts"
	},
	"dependencies": {
		"@effect/atom-react": "4.0.0-beta.59",
		"@opentui/core": "0.2.1",
		"@opentui/react": "0.2.1",
		"effect": "4.0.0-beta.59",
		"ignore": "^7.0.5",
		"react": "19.2.5",
		"scheduler": "0.27.0"
	},
	"devDependencies": {
		"@effect/language-service": "0.85.1",
		"@types/bun": "1.3.12",
		"@types/react": "19.2.14",
		"oxfmt": "0.47.0",
		"oxlint": "1.62.0",
		"typescript": "6.0.2"
	}
}
