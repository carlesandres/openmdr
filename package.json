{
	"name": "openmdr",
	"version": "0.0.0",
	"description": "TUI-first markdown reader on opentui",
	"type": "module",
	"license": "MIT",
	"private": true,
	"bin": {
		"openmdr": "src/index.tsx"
	},
	"scripts": {
		"dev": "bun --watch src/index.tsx",
		"start": "bun run src/index.tsx",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --tsconfig tsconfig.json src/",
		"format": "oxfmt src/",
		"format:check": "oxfmt --check src/",
		"test": "bun test",
		"build": "bun run dev/build-standalone.ts",
		"smoke": "bun run dev/smoke.ts"
	},
	"dependencies": {
		"@effect/atom-react": "4.0.0-beta.59",
		"@opentui/core": "0.2.1",
		"@opentui/react": "0.2.1",
		"effect": "4.0.0-beta.59",
		"ignore": "^7.0.5",
		"react": "19.2.5",
		"scheduler": "0.27.0"
	},
	"devDependencies": {
		"@effect/language-service": "0.85.1",
		"@types/bun": "1.3.12",
		"@types/react": "19.2.14",
		"oxfmt": "0.47.0",
		"oxlint": "1.62.0",
		"typescript": "6.0.2"
	}
}
