{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/carlesandres/house/blob/main/schema/house-theme.schema.json",
  "title": "house theme",
  "description": "A theme definition for house. Compatible-ish with opencode TUI themes minus the diff* token cluster.",
  "type": "object",
  "required": ["theme"],
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "description": "Human-readable theme name. Falls back to the file basename."
    },
    "defs": {
      "type": "object",
      "description": "Named anchor colors. Tokens reference these by name.",
      "additionalProperties": { "$ref": "#/definitions/HexColor" }
    },
    "theme": {
      "type": "object",
      "description": "Token values. Permissive — unknown tokens are ignored, missing tokens fall back at resolve time.",
      "additionalProperties": { "$ref": "#/definitions/ColorValue" }
    }
  },
  "definitions": {
    "HexColor": {
      "type": "string",
      "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{4}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$"
    },
    "RefName": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "Variant": {
      "type": "object",
      "required": ["dark", "light"],
      "additionalProperties": false,
      "properties": {
        "dark": { "oneOf": [{ "$ref": "#/definitions/HexColor" }, { "$ref": "#/definitions/RefName" }] },
        "light": { "oneOf": [{ "$ref": "#/definitions/HexColor" }, { "$ref": "#/definitions/RefName" }] }
      }
    },
    "ColorValue": {
      "oneOf": [
        { "$ref": "#/definitions/HexColor" },
        { "$ref": "#/definitions/RefName" },
        { "$ref": "#/definitions/Variant" }
      ]
    }
  }
}
